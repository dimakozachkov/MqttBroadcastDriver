{
    "name": "dimakozachkov/mqtt-broadcast-driver",
    "description": "MQTT broadcast driver for Laravel, backed by EMQX",
    "keywords": ["laravel", "broadcasting", "mqtt", "emqx", "websocket", "echo"],
    "license": "MIT",
    "homepage": "https://github.com/dimakozachkov/MqttBroadcastDriver",
    "authors": [
        {
            "name": "Dmytro Kozachkov",
            "homepage": "https://github.com/dimakozachkov"
        }
    ],
    "support": {
        "issues": "https://github.com/dimakozachkov/MqttBroadcastDriver/issues",
        "source": "https://github.com/dimakozachkov/MqttBroadcastDriver"
    },
    "require": {
        "php": "^8.1",
        "illuminate/broadcasting": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "php-mqtt/client": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "DmytroKozachkov\\MqttBroadcast\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DmytroKozachkov\\MqttBroadcast\\MqttBroadcastServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
